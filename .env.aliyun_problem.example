# EA118 problem register module. Copy to .env.aliyun_problem and fill secrets locally.
DINGTALK_DOC_URL=https://alidocs.dingtalk.com/i/nodes/{{DINGTALK_NODE_TOKEN}}?iframeQuery={{ENCODED_IFRAME_QUERY}}
DINGTALK_DOC_TITLE=1.2.1 FY27-EA118机房现场问题管理
DINGTALK_LOGIN_HINT={{DINGTALK_ACCOUNT_DISPLAY_NAME}}

FEISHU_BITABLE_URL=https://vnet.feishu.cn/wiki/SOwsw315aiBJjgkl48ccoxIPntc?table=tblcTPsC1Z057ic8&view=vewD2Rmoz3
FEISHU_BITABLE_APP_TOKEN=JeMdbI3JjawMj1s1YGSc3MoBn7c
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET={{FEISHU_APP_SECRET}}

LOCAL_EXCEL_PATH=downloads/dingtalk_bitable_no_attachment_latest.xlsx
SYNC_MODE=insert_missing
FIELD_MAPPING_FILE=field_mapping_aliyun_problem.json
SHEET_NAME=EA118问题总表
HEADER_ROW=1
CREATE_MISSING_FIELDS=false

DINGTALK_DOWNLOAD_MODE=browser
DINGTALK_BROWSER_PROFILE=.browser/dingtalk
DINGTALK_BROWSER_TIMEOUT_SEC=300
DINGTALK_AUTO_CLICK_EXPORT=true
DINGTALK_EXPORT_KIND=bitable
DINGTALK_IMPORT_BROWSER_COOKIES=true
DINGTALK_BROWSER_COOKIE_SOURCE=auto

FEISHU_API_BASE=https://open.feishu.cn/open-apis

FEISHU_NOTIFY_ENABLED=true
FEISHU_NOTIFY_APP_ID=
FEISHU_NOTIFY_APP_SECRET=
FEISHU_NOTIFY_CHAT_ID={{TARGET_GROUP_CHAT_ID}}
FEISHU_NOTIFY_OPEN_ID=

FEISHU_MEMBER_LOOKUP_CHAT_ID={{MEMBER_LOOKUP_GROUP_CHAT_ID}}
