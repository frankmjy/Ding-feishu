# DingTalk document source
DINGTALK_DOC_URL=https://alidocs.dingtalk.com/i/nodes/{{DINGTALK_NODE_TOKEN}}
DINGTALK_DOC_TITLE={{DINGTALK_DOCUMENT_TITLE}}
DINGTALK_LOGIN_HINT={{DINGTALK_ACCOUNT_DISPLAY_NAME}}
DINGTALK_EXPORT_KIND=auto

# Feishu Bitable target
FEISHU_BITABLE_URL=https://your-tenant.feishu.cn/wiki/{{WIKI_TOKEN}}?table={{TABLE_ID}}&view={{VIEW_ID}}
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET={{FEISHU_APP_SECRET}}
# Optional: set this if you already know the Bitable app_token and want to skip wiki URL resolution.
FEISHU_BITABLE_APP_TOKEN=

# Local sync behavior
LOCAL_EXCEL_PATH=downloads/dingtalk_export.xlsx
SYNC_MODE=insert_missing
FIELD_MAPPING_FILE=field_mapping.json
SHEET_NAME={{WORKSHEET_NAME}}
HEADER_ROW=1
CREATE_MISSING_FIELDS=false

# DingTalk browser automation
DINGTALK_DOWNLOAD_MODE=direct,browser
DINGTALK_BROWSER_PROFILE=.browser/dingtalk
DINGTALK_BROWSER_TIMEOUT_SEC=300
DINGTALK_AUTO_LOGIN=true
DINGTALK_AUTO_CLICK_EXPORT=true
DINGTALK_IMPORT_BROWSER_COOKIES=true
DINGTALK_BROWSER_COOKIE_SOURCE=auto

# Feishu OpenAPI
FEISHU_API_BASE=https://open.feishu.cn/open-apis

# Optional Feishu notification after a successful sync.
FEISHU_NOTIFY_ENABLED=false
FEISHU_NOTIFY_APP_ID=
FEISHU_NOTIFY_APP_SECRET=
FEISHU_NOTIFY_CHAT_ID=
FEISHU_NOTIFY_OPEN_ID=
FEISHU_NOTIFY_WEBHOOK_URL=
FEISHU_NOTIFY_WEBHOOK_SECRET=

# Optional: map a text assignee column to Feishu user field by looking up names in this chat.
FEISHU_MEMBER_LOOKUP_CHAT_ID=
